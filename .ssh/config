# Ваш рабочий аккаунт (по умолчанию)
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_rsa  # Замените id_rsa на имя вашего рабочего ключа, если оно другое (например, id_ed25519)

# Ваш личный аккаунт
Host github-personal
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_personal  # Точное имя ключа, который вы только что создали